@model IEnumerable<EnterpriseProject.Web.ViewModels.Enterprise.EnterpriseViewModel>
@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Empresas Cadastradas</h2>
        <a asp-controller="Enterprise" asp-action="Register" class="btn btn-primary">Cadastrar Nova Empresa</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Nenhuma empresa cadastrada no momento.</div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().Id)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Name)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Cnpj)</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.Id</td>
                        <td class="align-middle">@item.Name</td>
                        <td class="align-middle">@item.Cnpj</td>
                        <td class="text-center align-middle">
                            <a asp-controller="Enterprise" asp-action="GetById" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Detalhes</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
